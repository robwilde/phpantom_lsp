<?php

class StringResult {
    public function strMethod(): void {}
}

class IntResult {
    public function intMethod(): void {}
}

interface TreeMapper
{
    /**
     * @return ($signature is "foo" ? StringResult : IntResult)
     */
    public function map(string $signature, $source);
}

function test(TreeMapper $mapper): void {
    $map = $mapper->map('foo', 'bar');
    $map-><>
}