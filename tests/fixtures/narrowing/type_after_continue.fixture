// test: type narrows after continue in foreach loop
// feature: completion
// Adapted from phpactor if-statement/type_after_continue.test
// expect: fooMethod(
---
<?php

class Foobar {
    public function fooMethod(): void {}
}

class Other {
    public function otherMethod(): void {}
}

/** @var Foobar|Other $foobar */
$foobar = new Foobar();

foreach ([1, 2] as $hello) {
    if (!$foobar instanceof Foobar) {
        continue;
    }

    $foobar-><>
}