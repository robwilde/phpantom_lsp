// test: enum implementing interface resolves interface methods
// feature: completion
// Adapted from phpactor enum/gh-2220.test
// expect: foo(
---
<?php

interface Foo
{
    public function foo(): string;
}

enum Test: string implements Foo
{
    case A = 'a';

    public function foo(): string
    {
        return 'bar';
    }
}

Test::A-><>